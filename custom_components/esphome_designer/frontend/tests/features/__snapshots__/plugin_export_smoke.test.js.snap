exports[`Plugin Export Smoke Tests > Export for battery_icon > should export LVGL with stable output 1`] = `
{
  "obj": {
    "bg_opa": "transp",
    "border_width": 0,
    "widgets": [
      {
        "label": {
          "align": "top_mid",
          "height": 40,
          "id": "w_test_icon",
          "text": "!lambda |-
          if (id(battery_level).has_state()) {
            float lvl = id(battery_level).state;
            if (lvl >= 95) return "\\U000F0079";
            if (lvl >= 85) return "\\U000F0082";
            if (lvl >= 75) return "\\U000F0081";
            if (lvl >= 65) return "\\U000F0080";
            if (lvl >= 55) return "\\U000F007F";
            if (lvl >= 45) return "\\U000F007E";
            if (lvl >= 35) return "\\U000F007D";
            if (lvl >= 25) return "\\U000F007C";
            if (lvl >= 15) return "\\U000F007B";
            if (lvl >= 5) return "\\U000F007A";
            return "\\U000F0083";
          }
          return "\\U000F0083";",
          "text_color": "Color(theme_auto)",
          "text_font": "font_ptr",
          "width": 46,
        },
      },
      {
        "label": {
          "align": "bottom_mid",
          "height": 18,
          "id": "w_test_text",
          "text": "!lambda |-
          if (id(battery_level).has_state()) {
            return str_sprintf("%.0f%%", id(battery_level).state).c_str();
          }
          return "---%";",
          "text_align": "center",
          "text_color": "Color(theme_auto)",
          "text_font": "font_ptr",
          "width": "100%",
          "y": 2,
        },
      },
    ],
  },
}
`;

