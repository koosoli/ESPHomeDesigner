exports[`Plugin Export Smoke Tests > Export for calendar > should export standard C++ with stable output 1`] = `
[
  "        {",
  "          auto now = id(ha_time).now();",
  "          int x = 10; int y = 10; int w = 100; int h = 100;",
  "          // Header",
  "          int headH = 123;",
  "          it.strftime(x + w/2, y + 2, id(font_id), Color(theme_auto), TextAlign::TOP_CENTER, "%d", now);",
  "          it.strftime(x + w/2, y + 76, id(font_id), Color(theme_auto), TextAlign::TOP_CENTER, "%A", now);",
  "          it.strftime(x + w/2, y + 104, id(font_id), Color(theme_auto), TextAlign::TOP_CENTER, "%B %Y", now);",
  "          it.line(x, y + headH, x + w, y + headH, Color(theme_auto));",
  "          // Days Grid",
  "          int gridY = y + headH + 5;",
  "          int cellW = w / 7;",
  "          int rowH = 18;",
  "          int r = 1;",
  "          const char* days[] = {"Mo", "Tu", "We", "Th", "Fr", "Sa", "Su"};",
  "          for(int i=0; i<7; i++) {",
  "            it.print(x + i*cellW + cellW/2, gridY, id(font_id), Color(theme_auto), TextAlign::TOP_CENTER, days[i]);",
  "          }",
  "          // Simple logic to find start of month",
  "          time_t t = now.timestamp;",
  "          struct tm *tm = localtime(&t);",
  "          tm->tm_mday = 1;",
  "          mktime(tm);",
  "          int startDay = (tm->tm_wday + 6) % 7; // 0=Mon",
  "          int daysInMonth = 31; // Simplified",
  "          if(now.month == 2) daysInMonth = (now.year % 4 == 0) ? 29 : 28;",
  "          else if(now.month == 4 || now.month == 6 || now.month == 9 || now.month == 11) daysInMonth = 30;",
  "          int c = startDay;",
  "          for(int d=1; d<=daysInMonth; d++) {",
  "            if(d == now.day_of_month) {",
  "               it.filled_circle(x + c*cellW + cellW/2, gridY + r*rowH + 6, 9, Color(theme_auto));",
  "               it.printf(x + c*cellW + cellW/2, gridY + r*rowH, id(font_id), Color::BLACK, TextAlign::TOP_CENTER, "%d", d);",
  "            } else {",
  "               it.printf(x + c*cellW + cellW/2, gridY + r*rowH, id(font_id), Color(theme_auto), TextAlign::TOP_CENTER, "%d", d);",
  "            }",
  "            c++; if(c>6) { c=0; r++; }",
  "          }",
  "          // Events (Real Data from Sensor)",
  "          auto extract_time = [](const char* datetime) -> std::string {",
  "              std::string datetimeStr(datetime);",
  "              size_t pos = datetimeStr.find('T');",
  "              if (pos != std::string::npos && pos + 3 < datetimeStr.size()) {",
  "                  return datetimeStr.substr(pos + 1, 5);",
  "              }",
  "              return "";",
  "          };",
  "",
  "          int eventY = gridY + (r+1)*rowH + 10;",
  "          int max_y = y + h - 5;",
  "          const int event_limit = 8;",
  "",
  "          if (id(calendar_data_sensor_esp_calendar_data).state.length() > 5 && id(calendar_data_sensor_esp_calendar_data).state != "unknown") {",
  "             JsonDocument doc;",
  "             DeserializationError error = deserializeJson(doc, id(calendar_data_sensor_esp_calendar_data).state);",
  "",
  "             if (!error) {",
  "                 JsonVariant root = doc.as<JsonVariant>();",
  "                 JsonArray days;",
  "",
  "                 if (root.is<JsonObject>() && root["days"].is<JsonArray>()) {",
  "                     days = root["days"];",
  "                 } else if (root.is<JsonArray>()) {",
  "                     days = root;",
  "                 }",
  "",
  "                 if (!days.isNull() && days.size() > 0) {",
  "                     int event_count = 0;",
  "                     // Separator line",
  "                     it.filled_rectangle(x + 10, eventY - 5, w - 20, 2, Color(theme_auto));",
  "",
  "                     for (JsonVariant dayEntry : days) {",
  "                         if (eventY > max_y || event_count >= event_limit) break;",
  "                         int currentDayNum = dayEntry["day"].as<int>();",
  "",
  "                         auto draw_row = [&](JsonVariant event, bool is_all_day) {",
  "                             if (eventY > max_y || event_count >= event_limit) return;",
  "                             const char* summary = event["summary"] | "No Title";",
  "                             const char* start = event["start"] | "";",
  "",
  "                             // Draw Day Number",
  "                             it.printf(x + 10, eventY, id(font_id), Color(theme_auto), TextAlign::TOP_LEFT, "%d", currentDayNum);",
  "",
  "                             // Draw Summary",
  "                             it.printf(x + 50, eventY, id(font_id), Color(theme_auto), TextAlign::TOP_LEFT, "%.25s", summary);",
  "",
  "                             // Draw Time",
  "                             if (is_all_day) {",
  "                                 it.printf(x + w - 10, eventY, id(font_id), Color(theme_auto), TextAlign::TOP_RIGHT, "All Day");",
  "                             } else {",
  "                                 std::string timeStr = extract_time(start);",
  "                                 it.printf(x + w - 10, eventY, id(font_id), Color(theme_auto), TextAlign::TOP_RIGHT, "%s", timeStr.c_str());",
  "                             }",
  "                             eventY += 24;",
  "                             event_count++;",
  "                         };",
  "",
  "                         if (dayEntry["all_day"].is<JsonArray>()) {",
  "                             for (JsonVariant event : dayEntry["all_day"].as<JsonArray>()) {",
  "                                 draw_row(event, true);",
  "                             }",
  "                         }",
  "                         if (dayEntry["other"].is<JsonArray>()) {",
  "                             for (JsonVariant event : dayEntry["other"].as<JsonArray>()) {",
  "                                 draw_row(event, false);",
  "                             }",
  "                         }",
  "                     }",
  "                 }",
  "             } else {",
  "                 ESP_LOGW("calendar", "JSON Parse Error: %s", error.c_str());",
  "             }",
  "          }",
  "        }",
]
`;

exports[`Plugin Export Smoke Tests > Export for calendar > should handle onExportTextSensors with stable output 1`] = `
[
  "- platform: homeassistant",
  "  id: calendar_data_sensor_esp_calendar_data",
  "  entity_id: sensor.esp_calendar_data",
  "  attribute: entries",
  "  internal: true",
  "",
  "# ============================================================================",
  "# CALENDAR EVENTS SETUP (HOME ASSISTANT)",
  "# 1. Download the 'Helper Script' from the Calendar widget's properties panel.",
  "# 2. Place it in your /config/python_scripts/ folder.",
  "# 3. Enable the python_script integration by adding this line to configuration.yaml:",
  "#",
  "#    python_script:",
  "#",
  "# 4. Add this template sensor configuration (configuration.yaml or packages):",
  "#",
  "# template:",
  "#   - trigger:",
  "#       - trigger: time_pattern",
  "#         minutes: '/15'",
  "#     action:",
  "#       - action: calendar.get_events",
  "#         target:",
  "#           entity_id:",
  "#           - calendar.example_1
#           - calendar.example_2",
  "#         data:",
  "#           duration:",
  "#             days: 14",
  "#         response_variable: calendar_events",
  "#       - action: python_script.esp_calendar_data_conversion",
  "#         data:",
  "#           calendar: "{{ calendar_events }}"",
  "#           now: "{{ now().isoformat().split('T')[0] }}"",
  "#         response_variable: output",
  "#     sensor:",
  "#       - name: ESP Calendar Data",
  "#         unique_id: esp_calendar_data",
  "#         state: "OK"",
  "#         attributes:",
  "#           entries: "{{ output.entries }}"",
  "#           closest_end_time: "{{ output.closest_end_time }}"",
  "#",
  "# 5. Restart HA (required for python_script), then Reload Template Entities.",
  "# ============================================================================",
]
`;

