              if (ws == "cloudy") return "\\U000F0590";
              if (ws == "exceptional") return "\\U000F0026";
              if (ws == "fog") return "\\U000F0591";
              if (ws == "hail") return "\\U000F0592";
              if (ws == "lightning") return "\\U000F0593";
              if (ws == "lightning-rainy") return "\\U000F067E";
              if (ws == "partlycloudy") return "\\U000F0595";
              if (ws == "pouring") return "\\U000F0596";
              if (ws == "rainy") return "\\U000F0597";
              if (ws == "snowy") return "\\U000F0598";
              if (ws == "snowy-rainy") return "\\U000F067F";
              if (ws == "sunny") return "\\U000F0599";
              if (ws == "windy") return "\\U000F059D";
