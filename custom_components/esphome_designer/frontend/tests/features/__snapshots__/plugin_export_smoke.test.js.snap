{
  "obj": {
    "bg_opa": "transp",
    "border_width": 0,
    "widgets": [
      {
        "label": {
          "align": "top_mid",
          "height": 28,
          "text": "!lambda |-
          if (id(wifi_signal_dbm).has_state()) {
            float sig = id(wifi_signal_dbm).state;
            if (sig >= -50) return "\\U000F0928";
            if (sig >= -60) return "\\U000F0925";
            if (sig >= -75) return "\\U000F0922";
            if (sig >= -100) return "\\U000F091F";
            return "\\U000F092B";
          }
          return "\\U000F092B";",
          "text_color": "Color(theme_auto)",
          "text_font": "font_ptr",
