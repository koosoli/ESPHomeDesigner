  "            auto t = id(ha_time).now();",
  "            if (!t.is_valid()) return "---";",
  "            ESPTime future = ESPTime::from_epoch_local(t.timestamp + (target_day * 86400));",
  "            char buf[8]; future.strftime(buf, sizeof(buf), "%a");",
