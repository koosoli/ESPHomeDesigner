{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": false,
        "noImplicitAny": false,
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "baseUrl": "./custom_components/esphome_designer/frontend",
        "paths": {
            "@core/*": [
                "js/core/*"
            ],
            "@features/*": [
                "features/*"
            ],
            "@io/*": [
                "js/io/*"
            ]
        }
    },
    "include": [
        "custom_components/esphome_designer/frontend/js/**/*",
        "custom_components/esphome_designer/frontend/features/**/*",
        "custom_components/esphome_designer/frontend/types.d.ts"
    ],
    "exclude": [
        "node_modules",
        "custom_components/esphome_designer/frontend/dist",
        "**/*.cjs",
        "scripts/*.cjs",
        "vite.config.js",
        "vitest.config.js"
    ]
}