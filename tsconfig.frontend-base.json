{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "custom_components/esphome_designer/frontend/js/**/*",
    "custom_components/esphome_designer/frontend/features/**/*",
    "custom_components/esphome_designer/frontend/types.d.ts",
    "strict-shims.d.ts"
  ],
  "exclude": [
    "node_modules",
    "custom_components/esphome_designer/frontend/dist",
    "custom_components/esphome_designer/frontend/js/core/plugin_registry.ts",
    "**/plugin_registry.ts",
    "**/*.cjs",
    "scripts/*.cjs",
    "vite.config.js",
    "vitest.config.js"
  ]
}
